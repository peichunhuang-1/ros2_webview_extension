{
  "name": "ros2-webview-extension",
  "displayName": "ros2-webview-extension",
  "description": "for creating ros2 web-viewer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ros2-webview-extension.setupClaudeCodeMcp",
        "title": "ROS2 Webview: Set Up Claude Code MCP Integration"
      },
      {
        "command": "ros2-webview-extension.previewGeneratedUi",
        "title": "ROS2 Webview: Preview Generated UI",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ros2-webview-extension.previewGeneratedUi",
          "when": "resourceExtname == .html",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "webviewSidebar",
          "title": "Webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "webviewSidebar": [
        {
          "type": "webview",
          "id": "editorWebview",
          "name": "Webview",
          "icon": "media/icon.svg"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "ros2-webview-extension.mcpServers",
        "label": "ROS2 Interfaces"
      }
    ],
    "configuration": {
      "title": "ros2 webview",
      "properties": {
        "ros2Webview.rosbridgeUrl": {
          "type": "string",
          "default": "ws://localhost:9090",
          "description": "WebSocket URL of the rosbridge_server instance that Claude-generated web GUIs should connect to via roslibjs."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "vsce package"
  },
  "optionalDependencies": {
    "rclnodejs": "^1.7.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.102.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "axios": "^1.11.0",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "zod": "^4.4.3"
  }
}
