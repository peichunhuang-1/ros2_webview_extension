{
  "name": "ros2-webview-extension",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // VS Code extension host process does not source .bashrc,
  // so we set ROS2 vars explicitly here for the whole remote session.
  "remoteEnv": {
    "AMENT_PREFIX_PATH": "/opt/ros/humble",
    "ROS_DISTRO": "humble",
    "ROS_VERSION": "2",
    "RMW_IMPLEMENTATION": "rmw_fastrtps_cpp",
    "LD_LIBRARY_PATH": "/opt/ros/humble/lib:/opt/ros/humble/lib/aarch64-linux-gnu:/opt/ros/humble/lib/x86_64-linux-gnu:${containerEnv:LD_LIBRARY_PATH}",
    "PATH": "/opt/ros/humble/bin:${containerEnv:PATH}",
    "PYTHONPATH": "/opt/ros/humble/local/lib/python3.10/dist-packages:/opt/ros/humble/lib/python3.10/site-packages:${containerEnv:PYTHONPATH}"
  },

  "postCreateCommand": "npm install && npm install --prefix media/web-content",

  // Host networking so rosbridge_server's DDS discovery (rmw_fastrtps_cpp) can reach
  // ROS2 nodes outside the container without multicast/NAT issues. Container and host
  // share the same network stack, so no forwardPorts entry is needed (or safe) here.
  // if you insist using forward uncomment forwardPorts and comment runArgs
  // "forwardPorts": [9090],
  "runArgs": ["--network=host"],

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}
